{
  "name": "slyght",
  "version": "1.0.0",
  "scripts": {
    "guardian-static": "node guardian-static.js",
    "guardian-all": "node guardian-all.js",
    "guardian": "node guardian-all.js && node guardian-static.js",
    "runtime": "node guardian-runtime.js",
    "capture": "node capture-state.js",
    "serve": "node scripts/serve.js",
    "visual": "playwright test",
    "visual:update": "playwright test --update-snapshots",
    "visual:report": "playwright show-report",
    "smoke": "playwright test --config=playwright.smoke.config.js",
    "smoke:report": "playwright show-report",
    "verify-visual": "node scripts/verify-visual-state.js",
    "verify-visual:force": "node scripts/verify-visual-state.js --force",
    "test:all": "npm run smoke && npm run verify-visual",
    "recon:dump": "node scripts/recon/dump-state.js",
    "recon:apply": "node scripts/recon/reconcile-against-bank.js",
    "layerV": "node scripts/layerV-capture.js --local --skip-deep",
    "layerV:deep": "node scripts/layerV-capture.js --local --deep-only",
    "layerV:all": "node scripts/layerV-capture.js --local",
    "layerV:sweep": "node scripts/layerV-capture.js --local --deep-only --sweep-package",
    "layerV:dark": "node scripts/layerV-capture.js --local --deep-only --theme dark",
    "layerV:light": "node scripts/layerV-capture.js --local --deep-only --theme light",
    "layerV:sweep:dark": "node scripts/layerV-capture.js --local --deep-only --theme dark --sweep-package",
    "test:interaction": "node scripts/mission-i/run.js",
    "test:interaction:dry": "node scripts/mission-i/run.js --dry-run",
    "test": "node guardian-all.js && node guardian-static.js && node tests/core.test.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "canvas": "^3.2.3"
  }
}
